<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Synthwave Courier: Last Cartridge v2.0</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap');
    * { box-sizing: border-box; user-select: none; }
    html, body {
      margin: 0; width: 100%; height: 100%; overflow: hidden;
      background: #070010;
      font-family: 'Share Tech Mono', 'Courier New', monospace;
      color: #fff;
    }
    #game {
      display: block; width: 100vw; height: 100vh;
      image-rendering: pixelated;
      background: radial-gradient(circle at center, #18002e 0%, #06000f 70%);
    }
    .overlay {
      position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;
      background: rgba(4, 0, 12, 0.85); backdrop-filter: blur(4px); z-index: 10;
    }
    .panel {
      width: min(820px, 94vw);
      border: 2px solid #ff2bd6;
      box-shadow: 0 0 40px #ff2bd6, 0 0 80px rgba(255,43,214,0.3), inset 0 0 30px rgba(255, 43, 214, 0.12);
      padding: 36px;
      background: linear-gradient(180deg, rgba(16, 0, 36, 0.98), rgba(8, 0, 20, 0.99));
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .panel::before {
      content: '';
      position: absolute; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,43,214,0.03) 3px, rgba(255,43,214,0.03) 4px);
      pointer-events: none;
    }
    .title {
      margin: 0 0 6px;
      font-family: 'Orbitron', monospace;
      font-size: clamp(26px, 5.5vw, 58px);
      font-weight: 900;
      color: #00f5ff;
      text-shadow: 0 0 20px #00f5ff, 0 0 40px rgba(0,245,255,0.5), 4px 4px 0 #ff2bd6;
      letter-spacing: 3px;
      text-transform: uppercase;
    }
    .title-sub {
      font-family: 'Orbitron', monospace;
      font-size: clamp(11px, 1.8vw, 16px);
      color: #ff2bd6;
      letter-spacing: 6px;
      margin-bottom: 20px;
      text-transform: uppercase;
    }
    .subtitle {
      margin: 0 0 18px;
      font-size: clamp(13px, 1.6vw, 16px);
      color: #e8d7ff;
      line-height: 1.6;
    }
    .story-box {
      border: 1px solid rgba(255,209,102,0.4);
      background: rgba(255,209,102,0.05);
      padding: 14px 18px;
      margin: 0 0 20px;
      text-align: left;
      font-size: clamp(12px, 1.4vw, 14px);
      color: #ffd166;
      line-height: 1.6;
    }
    .controls {
      margin: 18px auto;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      text-align: left;
      max-width: 640px;
      color: #e8d7ff;
      font-size: clamp(12px, 1.4vw, 15px);
    }
    .ctrl-item { display: flex; align-items: center; gap: 8px; }
    .key {
      color: #00f5ff; font-weight: 700;
      background: rgba(0,245,255,0.1);
      border: 1px solid rgba(0,245,255,0.4);
      padding: 2px 8px;
      border-radius: 2px;
      white-space: nowrap;
    }
    .button {
      display: inline-block; margin-top: 16px;
      padding: 14px 32px;
      border: 2px solid #00f5ff; color: #00f5ff;
      background: rgba(0, 245, 255, 0.08);
      box-shadow: 0 0 20px rgba(0, 245, 255, 0.6), inset 0 0 10px rgba(0,245,255,0.05);
      text-transform: uppercase; letter-spacing: 3px;
      font-weight: 700; font-size: 16px;
      font-family: 'Orbitron', monospace;
      animation: buttonPulse 1.8s ease-in-out infinite;
      cursor: pointer;
    }
    @keyframes buttonPulse {
      0%, 100% { box-shadow: 0 0 20px rgba(0, 245, 255, 0.6); }
      50% { box-shadow: 0 0 36px rgba(0, 245, 255, 0.9), 0 0 60px rgba(0,245,255,0.3); }
    }
    .hidden { display: none !important; }
    .scanlines::before {
      content: "";
      position: fixed; inset: 0; pointer-events: none;
      background: repeating-linear-gradient(to bottom, rgba(255,255,255,0.028), rgba(255,255,255,0.028) 1px, transparent 1px, transparent 4px);
      z-index: 20; mix-blend-mode: screen;
    }
    .scanlines::after {
      content: ""; position: fixed; inset: 0; pointer-events: none;
      box-shadow: inset 0 0 140px rgba(0,0,0,0.92);
      z-index: 21;
    }
    #result .title { animation: glitch 0.1s steps(1) infinite; }
    @keyframes glitch {
      0%, 90%, 100% { text-shadow: 0 0 20px #00f5ff, 4px 4px 0 #ff2bd6; }
      91% { text-shadow: -4px 0 #ff2bd6, 4px 4px 0 #00f5ff; transform: translateX(3px); }
      93% { text-shadow: 4px 0 #00f5ff, -4px 4px 0 #ff2bd6; transform: translateX(-2px); }
      95% { text-shadow: 0 0 20px #00f5ff, 4px 4px 0 #ff2bd6; transform: translateX(0); }
    }
    .rank-badge {
      display: inline-block;
      font-family: 'Orbitron', monospace;
      font-size: clamp(40px, 8vw, 72px);
      font-weight: 900;
      margin: 8px 0;
      padding: 8px 24px;
      border: 3px solid currentColor;
    }
    .rank-S { color: #ffd166; text-shadow: 0 0 30px #ffd166; border-color: #ffd166; box-shadow: 0 0 30px rgba(255,209,102,0.4); }
    .rank-A { color: #00f5ff; text-shadow: 0 0 24px #00f5ff; border-color: #00f5ff; }
    .rank-B { color: #ff2bd6; text-shadow: 0 0 20px #ff2bd6; border-color: #ff2bd6; }
    .rank-C { color: #888; border-color: #888; }
    .score-breakdown {
      display: flex; gap: 16px; justify-content: center;
      flex-wrap: wrap; margin: 10px 0;
    }
    .score-item { font-size: 13px; color: #aaa; }
    .score-item span { color: #ffd166; font-size: 15px; }
    #comboDisplay {
      position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
      pointer-events: none; z-index: 50;
      font-family: 'Orbitron', monospace;
      font-size: 48px; font-weight: 900;
      opacity: 0; transition: opacity 0.1s;
    }
    #dangerBar {
      position: fixed; bottom: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, #ff2bd6, #ff6b2b);
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.3s ease;
      z-index: 30;
    }
  </style>
</head>
<body class="scanlines">
  <canvas id="game"></canvas>
  <div id="comboDisplay"></div>
  <div id="dangerBar"></div>

  <div id="menu" class="overlay">
    <div class="panel">
      <h1 class="title">Synthwave Courier</h1>
      <div class="title-sub">Last Cartridge · 1987</div>
      <div class="story-box">
        Корпорация NEXACOM закрывает последние аркадные клубы города.<br>
        У тебя — последний картридж и ровно <strong style="color:#ff2bd6">105 секунд</strong> до полуночи.<br>
        Если доставишь — аркадная сцена выживет. Нет — она умрёт навсегда.
      </div>
      <div class="controls">
        <div class="ctrl-item"><span class="key">W/↑</span> Газ</div>
        <div class="ctrl-item"><span class="key">S/↓</span> Тормоз / задний ход</div>
        <div class="ctrl-item"><span class="key">A/←  D/→</span> Поворот</div>
        <div class="ctrl-item"><span class="key">SHIFT</span> Нитро (боост)</div>
        <div class="ctrl-item"><span class="key">M</span> Мини-карта вкл/выкл</div>
        <div class="ctrl-item"><span class="key">R</span> Рестарт</div>
        <div class="ctrl-item"><span class="key">SPACE</span> Пауза</div>
        <div class="ctrl-item"><span class="key">TAB</span> Маршрут вкл/выкл</div>
      </div>
      <p class="subtitle" style="margin-top:12px; font-size:13px; color:#aaa">
        🟡 Жёлтая линия = рекомендованный маршрут &nbsp;|&nbsp; 🔵 Синие падды = ускорение<br>
        ⚡ Бонусы: B = боост, + = ремонт, T = +время &nbsp;|&nbsp; 🔴 Дроны = урон
      </p>
      <div class="button" onclick="startGame()">▶ НАЖМИ SPACE</div>
    </div>
  </div>

  <div id="result" class="overlay hidden">
    <div class="panel">
      <h1 id="resultTitle" class="title">Result</h1>
      <div id="rankDisplay"></div>
      <div id="scoreBreakdown" class="score-breakdown"></div>
      <p id="resultText" class="subtitle"></p>
      <div class="button" onclick="startGame()">▶ SPACE — снова</div>
    </div>
  </div>

  <script>
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    const menu = document.getElementById('menu');
    const result = document.getElementById('result');
    const resultTitle = document.getElementById('resultTitle');
    const resultText = document.getElementById('resultText');
    const comboDisplay = document.getElementById('comboDisplay');
    const dangerBar = document.getElementById('dangerBar');

    const WORLD = { width: 2400, height: 1600 };
    const keys = new Set();

    let state = 'menu';
    let lastTime = 0;
    let shake = 0;
    let flash = 0;
    let flashColor = '#ff2bd6';
    let minimapEnabled = true;
    let timeLeft = 105;
    let audioStarted = false;
    let audioCtx = null;
    let engineOsc = null;
    let engineGain = null;
    let recommendedRouteVisible = true;
    let paused = false;
    let combo = 0;
    let comboTimer = 0;
    let comboMultiplier = 1;
    let comboShowTimer = 0;
    let totalScore = 0;
    let totalBonusesTaken = 0;
    let totalDamageReceived = 0;
    let levelTimer = 0;

    // Tune - simple synthwave arpeggio
    let tuneScheduled = 0;
    const TUNE_NOTES = [220, 277, 330, 415, 330, 277, 220, 165];
    let tuneIdx = 0;

    const player = {
      x: 160, y: WORLD.height - 180,
      w: 34, h: 54,
      angle: -Math.PI / 2,
      speed: 0,
      maxSpeed: 430,
      boostMaxSpeed: 640,
      acceleration: 800,
      brake: 1020,
      friction: 0.970,
      turnSpeed: 5.1,
      lowSpeedTurnBoost: 1.6,
      hp: 100,
      boost: 100,
      score: 0,
      invincible: 0,
      driftAngle: 0
    };

    const camera = { x: 0, y: 0 };
    const destination = { x: WORLD.width - 260, y: 180, w: 170, h: 120 };

    const roads = [
      { x: 80, y: WORLD.height - 260, w: 2100, h: 150 },
      { x: 520, y: 240, w: 150, h: 1200 },
      { x: 1000, y: 120, w: 150, h: 1260 },
      { x: 1500, y: 260, w: 150, h: 1180 },
      { x: 1900, y: 120, w: 150, h: 1250 },
      { x: 240, y: 620, w: 1850, h: 140 },
      { x: 320, y: 1040, w: 1780, h: 140 },
      { x: 960, y: 120, w: 1120, h: 140 }
    ];

    const buildings = [];
    const drones = [];
    const bonuses = [];
    const glitches = [];
    const neonSigns = [];
    const roadLights = [];
    const cityParticles = [];
    const carTrails = [];
    const boostPads = [];
    const finishSparks = [];
    const floatingTexts = [];
    const exhaustParticles = [];
    const explosionParticles = [];
    const radarPings = [];

    const routeBeacons = [
      { x: 580, y: 1415, label: '01' },
      { x: 580, y: 1110, label: '02' },
      { x: 1075, y: 1110, label: '03' },
      { x: 1075, y: 690, label: '04' },
      { x: 1565, y: 690, label: '05' },
      { x: 1565, y: 330, label: '06' },
      { x: 1975, y: 190, label: '07' },
      { x: destination.x + destination.w / 2, y: destination.y + destination.h / 2, label: 'CLUB' }
    ];

    function resize() {
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(window.innerHeight * dpr);
      canvas.style.width = window.innerWidth + 'px';
      canvas.style.height = window.innerHeight + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    window.addEventListener('resize', resize);
    resize();

    window.addEventListener('keydown', (e) => {
      keys.add(e.key.toLowerCase());
      if (e.code === 'Space') {
        if (state === 'menu') startGame();
        else if (state === 'win' || state === 'lose') startGame();
        else if (state === 'playing') { paused = !paused; }
      }
      if (e.key.toLowerCase() === 'r' && state !== 'menu') startGame();
      if (e.key.toLowerCase() === 'm') minimapEnabled = !minimapEnabled;
      if (e.key === 'Tab') { e.preventDefault(); recommendedRouteVisible = !recommendedRouteVisible; }
    });
    window.addEventListener('keyup', (e) => keys.delete(e.key.toLowerCase()));

    function startGame() {
      startAudio();
      state = 'playing';
      paused = false;
      menu.classList.add('hidden');
      result.classList.add('hidden');
      player.x = 160; player.y = WORLD.height - 180;
      player.angle = -Math.PI / 2;
      player.speed = 0; player.hp = 100; player.boost = 100; player.score = 0;
      player.invincible = 0; player.driftAngle = 0;
      timeLeft = 105;
      recommendedRouteVisible = true;
      shake = 0; flash = 0; combo = 0; comboTimer = 0; comboMultiplier = 1;
      totalScore = 0; totalBonusesTaken = 0; totalDamageReceived = 0; levelTimer = 0;
      tuneIdx = 0; tuneScheduled = 0;
      floatingTexts.length = 0;
      exhaustParticles.length = 0;
      explosionParticles.length = 0;
      radarPings.length = 0;
      dangerBar.style.transform = 'scaleX(0)';
      createWorldObjects();
    }

    function startAudio() {
      if (audioStarted) return;
      audioStarted = true;
      try {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        engineOsc = audioCtx.createOscillator();
        engineGain = audioCtx.createGain();
        engineOsc.type = 'sawtooth';
        engineOsc.frequency.value = 50;
        engineGain.gain.value = 0.006;
        engineOsc.connect(engineGain);
        engineGain.connect(audioCtx.destination);
        engineOsc.start();
      } catch (e) {}
    }

    function beep(freq = 440, duration = 0.045, volume = 0.026, type = 'square') {
      if (!audioCtx) return;
      try {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.value = freq;
        gain.gain.value = volume;
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
        osc.stop(audioCtx.currentTime + duration);
      } catch(e) {}
    }

    function playTune(dt) {
      if (!audioCtx || state !== 'playing' || paused) return;
      tuneScheduled -= dt;
      if (tuneScheduled <= 0) {
        tuneScheduled = 0.22;
        const note = TUNE_NOTES[tuneIdx % TUNE_NOTES.length];
        try {
          const osc = audioCtx.createOscillator();
          const gain = audioCtx.createGain();
          const filter = audioCtx.createBiquadFilter();
          filter.type = 'lowpass';
          filter.frequency.value = 1200;
          osc.type = 'square';
          osc.frequency.value = note;
          gain.gain.value = 0.008;
          osc.connect(filter);
          filter.connect(gain);
          gain.connect(audioCtx.destination);
          osc.start();
          gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.18);
          osc.stop(audioCtx.currentTime + 0.2);
        } catch(e) {}
        tuneIdx++;
      }
    }

    function addFloatingText(x, y, text, color = '#ffd166', size = 18) {
      floatingTexts.push({ x, y, text, color, size, life: 1.0, vy: -60 });
    }

    function addExplosion(x, y, color = '#ff2bd6', count = 12) {
      for (let i = 0; i < count; i++) {
        const angle = (Math.PI * 2 / count) * i + Math.random() * 0.5;
        const speed = 80 + Math.random() * 180;
        explosionParticles.push({
          x, y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: 0.4 + Math.random() * 0.4,
          size: 2 + Math.random() * 4,
          color
        });
      }
    }

    function createWorldObjects() {
      buildings.length = 0; drones.length = 0; bonuses.length = 0;
      glitches.length = 0; neonSigns.length = 0; roadLights.length = 0;
      boostPads.length = 0; finishSparks.length = 0;
      carTrails.length = 0; cityParticles.length = 0;
      const blockedRects = [...roads, destination];

      for (let y = 80; y < WORLD.height - 80; y += 210) {
        for (let x = 80; x < WORLD.width - 80; x += 260) {
          const b = {
            x: x + Math.random() * 40, y: y + Math.random() * 40,
            w: 110 + Math.random() * 80, h: 90 + Math.random() * 80,
            glow: Math.random(), colorIdx: Math.floor(Math.random() * 3)
          };
          if (!blockedRects.some(r => rectsOverlap(inflate(b, 60), r))) buildings.push(b);
        }
      }

      // Patrol drones (more interesting patterns)
      const droneConfigs = [
        { patrol: 'horizontal' }, { patrol: 'vertical' }, { patrol: 'circle' },
        { patrol: 'horizontal' }, { patrol: 'circle' }, { patrol: 'vertical' },
        { patrol: 'horizontal' }, { patrol: 'circle' }, { patrol: 'vertical' }, { patrol: 'horizontal' }
      ];
      for (let i = 0; i < 10; i++) {
        const road = roads[(i + 2) % roads.length];
        drones.push({
          x: road.x + 40 + Math.random() * Math.max(10, road.w - 80),
          y: road.y + 40 + Math.random() * Math.max(10, road.h - 80),
          r: 22, vx: (Math.random() - 0.5) * 100, vy: (Math.random() - 0.5) * 100,
          phase: Math.random() * Math.PI * 2,
          patrol: droneConfigs[i].patrol,
          startX: 0, startY: 0, patrolRange: 200 + Math.random() * 200,
          cooldown: Math.random() * 2,
          alertRadius: 350,
          alerted: false
        });
        drones[drones.length - 1].startX = drones[drones.length - 1].x;
        drones[drones.length - 1].startY = drones[drones.length - 1].y;
      }

      const bonusTypes = ['boost', 'repair', 'time', 'score', 'score'];
      for (let i = 0; i < 22; i++) {
        const road = roads[Math.floor(Math.random() * roads.length)];
        bonuses.push({
          x: road.x + 30 + Math.random() * Math.max(10, road.w - 60),
          y: road.y + 30 + Math.random() * Math.max(10, road.h - 60),
          r: 15, type: bonusTypes[i % bonusTypes.length], taken: false, pulse: Math.random() * Math.PI * 2
        });
      }

      for (let i = 0; i < 18; i++) {
        const road = roads[Math.floor(Math.random() * roads.length)];
        glitches.push({
          x: road.x + Math.random() * road.w, y: road.y + Math.random() * road.h,
          w: 30 + Math.random() * 40, h: 16 + Math.random() * 26,
          damage: 11, phase: Math.random() * Math.PI * 2
        });
      }

      createVisualObjects();
      createGameplayObjects();
    }

    function createGameplayObjects() {
      const padPoints = [
        { x: 360, y: 1415, angle: 0 },
        { x: 720, y: 1110, angle: 0 },
        { x: 1260, y: 690, angle: 0 },
        { x: 1565, y: 510, angle: -Math.PI / 2 },
        { x: 1840, y: 190, angle: 0 },
        { x: 2070, y: 190, angle: 0 }
      ];
      for (const p of padPoints) {
        boostPads.push({ x: p.x, y: p.y, w: 72, h: 34, angle: p.angle, pulse: Math.random() * Math.PI * 2, cooldown: 0 });
      }
    }

    function createVisualObjects() {
      const signTexts = ['TARGEM', 'READY', '1986', 'ARCADE', 'NEON', 'INSERT COIN', 'LEVEL UP', 'CRT', 'GAME ON', 'HI-SCORE', 'PIXEL', 'RETRO'];
      for (let i = 0; i < 26; i++) {
        const b = buildings[Math.floor(Math.random() * buildings.length)];
        if (!b) continue;
        neonSigns.push({
          x: b.x + 8 + Math.random() * Math.max(8, b.w - 70),
          y: b.y + 12 + Math.random() * Math.max(8, b.h - 40),
          w: 42 + Math.random() * 34, h: 14 + Math.random() * 12,
          text: signTexts[i % signTexts.length],
          phase: Math.random() * Math.PI * 2,
          color: i % 2 === 0 ? '#00f5ff' : '#ff2bd6',
          flickerRate: 0.5 + Math.random() * 2
        });
      }

      for (const r of roads) {
        const horizontal = r.w > r.h;
        const count = Math.floor((horizontal ? r.w : r.h) / 170);
        for (let i = 1; i < count; i++) {
          roadLights.push({
            x: horizontal ? r.x + i * 170 : r.x + r.w / 2,
            y: horizontal ? r.y + 18 : r.y + i * 170,
            side: -1, phase: Math.random() * Math.PI * 2
          });
          roadLights.push({
            x: horizontal ? r.x + i * 170 : r.x + r.w / 2,
            y: horizontal ? r.y + r.h - 18 : r.y + i * 170,
            side: 1, phase: Math.random() * Math.PI * 2
          });
        }
      }
    }

    function inflate(rect, amount) { return { x: rect.x - amount, y: rect.y - amount, w: rect.w + amount * 2, h: rect.h + amount * 2 }; }
    function rectsOverlap(a, b) { return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y; }
    function circleRectOverlap(circle, rect) {
      const cx = Math.max(rect.x, Math.min(circle.x, rect.x + rect.w));
      const cy = Math.max(rect.y, Math.min(circle.y, rect.y + rect.h));
      const dx = circle.x - cx; const dy = circle.y - cy;
      return dx * dx + dy * dy < circle.r * circle.r;
    }
    function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }
    function distance(a, b, c, d) { return Math.hypot(a - c, b - d); }

    function update(dt) {
      if (state !== 'playing' || paused) return;
      levelTimer += dt;
      playTune(dt);

      if (engineOsc && engineGain) {
        engineOsc.frequency.value = 44 + Math.abs(player.speed) * 0.075;
        engineGain.gain.value = 0.004 + Math.min(0.01, Math.abs(player.speed) / 76000);
      }

      timeLeft -= dt;
      // Danger bar: low time warning
      if (timeLeft < 30) {
        dangerBar.style.transform = `scaleX(${1 - timeLeft / 30})`;
        dangerBar.style.opacity = 0.7 + 0.3 * Math.sin(Date.now() / 120);
      }
      if (timeLeft <= 0) endGame(false, 'timeout');

      const forward = keys.has('w') || keys.has('arrowup');
      const backward = keys.has('s') || keys.has('arrowdown');
      const left = keys.has('a') || keys.has('arrowleft');
      const right = keys.has('d') || keys.has('arrowright');
      const boost = keys.has('shift') && player.boost > 0 && player.speed > 80;

      const maxSpeed = boost ? player.boostMaxSpeed : player.maxSpeed;
      if (forward) player.speed += player.acceleration * dt;
      else if (backward) player.speed -= player.brake * dt;
      else player.speed *= Math.pow(player.friction, dt * 60);
      player.speed = clamp(player.speed, -185, maxSpeed);

      if (boost) player.boost = Math.max(0, player.boost - 34 * dt);
      else player.boost = Math.min(100, player.boost + 13 * dt);

      // Improved turn: drift effect at high speed
      const speedAbs = Math.abs(player.speed);
      const speedTurnFactor = clamp(speedAbs / 260, 0.42, 1.1);
      const lowSpeedBoost = speedAbs < 145 ? player.lowSpeedTurnBoost : 1;
      const turnDir = (left ? -1 : 0) + (right ? 1 : 0);
      player.driftAngle = clamp(player.driftAngle + turnDir * dt * 6 - player.driftAngle * dt * 8, -0.22, 0.22);
      if (turnDir !== 0) {
        player.angle += turnDir * player.turnSpeed * speedTurnFactor * lowSpeedBoost * dt * Math.sign(player.speed || 1);
      }

      const oldX = player.x; const oldY = player.y;
      if (speedAbs > 60) {
        carTrails.push({
          x: player.x - Math.cos(player.angle) * 26 + (Math.random() - 0.5) * 8,
          y: player.y - Math.sin(player.angle) * 26 + (Math.random() - 0.5) * 8,
          life: 0.38 + (boost ? 0.1 : 0),
          size: 4 + Math.min(8, speedAbs / 90),
          boost
        });
      }
      // Exhaust particles at high speed
      if (speedAbs > 200 || boost) {
        exhaustParticles.push({
          x: player.x - Math.cos(player.angle) * 32,
          y: player.y - Math.sin(player.angle) * 32,
          vx: -Math.cos(player.angle) * (30 + Math.random() * 60) + (Math.random() - 0.5) * 40,
          vy: -Math.sin(player.angle) * (30 + Math.random() * 60) + (Math.random() - 0.5) * 40,
          life: 0.25 + Math.random() * 0.2,
          color: boost ? '#00f5ff' : '#ff9900'
        });
      }

      player.x += Math.cos(player.angle) * player.speed * dt;
      player.y += Math.sin(player.angle) * player.speed * dt;
      player.x = clamp(player.x, 30, WORLD.width - 30);
      player.y = clamp(player.y, 30, WORLD.height - 30);
      if (player.invincible > 0) player.invincible -= dt;

      const carRect = getPlayerRect();
      const onRoad = roads.some(r => rectsOverlap(carRect, r));
      if (!onRoad) { player.speed *= 0.87; if (player.invincible <= 0) player.hp -= 5 * dt; }

      for (const b of buildings) {
        if (rectsOverlap(carRect, b)) {
          player.x = oldX; player.y = oldY;
          player.speed *= -0.28;
          if (player.invincible <= 0) {
            player.hp -= 14 * dt;
            totalDamageReceived += 14 * dt;
            shake = Math.max(shake, 8);
            flashColor = '#ff2bd6'; flash = Math.max(flash, 0.09);
            beep(90, 0.03, 0.012, 'sawtooth');
            resetCombo();
          }
        }
      }

      for (const g of glitches) {
        if (rectsOverlap(carRect, g) && player.invincible <= 0) {
          player.hp -= g.damage * dt;
          totalDamageReceived += g.damage * dt;
          player.speed *= 0.988;
          flash = Math.max(flash, 0.06);
          flashColor = '#ff2bd6';
          resetCombo();
        }
      }

      // Improved drone AI with patrol + chase
      for (const d of drones) {
        d.phase += dt * 2.8;
        d.cooldown -= dt;
        const dx = player.x - d.x; const dy = player.y - d.y;
        const dist = Math.hypot(dx, dy);
        d.alerted = dist < d.alertRadius;

        if (d.alerted) {
          // Chase mode
          d.vx += (dx / Math.max(1, dist)) * 90 * dt;
          d.vy += (dy / Math.max(1, dist)) * 90 * dt;
          if (!d._alertBeep) { beep(300, 0.06, 0.008, 'square'); d._alertBeep = true; }
          // Radar ping
          if (d.cooldown < -1 && Math.random() < 0.02) {
            radarPings.push({ x: d.x, y: d.y, r: 0, maxR: d.alertRadius, life: 1 });
          }
        } else {
          d._alertBeep = false;
          // Patrol - return toward start
          const backX = d.startX - d.x; const backY = d.startY - d.y;
          const backDist = Math.hypot(backX, backY);
          if (backDist > 20) {
            d.vx += (backX / backDist) * 40 * dt;
            d.vy += (backY / backDist) * 40 * dt;
          }
        }
        d.vx *= Math.pow(0.985, dt * 60);
        d.vy *= Math.pow(0.985, dt * 60);
        d.x += d.vx * dt; d.y += d.vy * dt;

        const road = roads.find(r => circleRectOverlap(d, r));
        if (!road || d.x < 30 || d.y < 30 || d.x > WORLD.width - 30 || d.y > WORLD.height - 30) {
          d.vx *= -0.7; d.vy *= -0.7;
          d.x = clamp(d.x, 40, WORLD.width - 40);
          d.y = clamp(d.y, 40, WORLD.height - 40);
        }
        if (circleRectOverlap(d, carRect) && player.invincible <= 0) {
          player.hp -= 22 * dt;
          totalDamageReceived += 22 * dt;
          player.speed *= 0.97;
          shake = Math.max(shake, 10);
          flashColor = '#ff2bd6'; flash = Math.max(flash, 0.08);
          if (d.cooldown <= 0) { beep(150, 0.04, 0.012, 'square'); d.cooldown = 0.45; }
          resetCombo();
          addExplosion(player.x, player.y, '#ff2bd6', 6);
        }
      }

      // Radar pings update
      for (let i = radarPings.length - 1; i >= 0; i--) {
        radarPings[i].r += radarPings[i].maxR * dt * 1.2;
        radarPings[i].life -= dt * 1.5;
        if (radarPings[i].life <= 0) radarPings.splice(i, 1);
      }

      for (const pad of boostPads) {
        pad.pulse += dt * 5;
        if (pad.cooldown > 0) pad.cooldown -= dt;
        const dx = player.x - pad.x; const dy = player.y - pad.y;
        if (Math.abs(dx) < 58 && Math.abs(dy) < 42 && pad.cooldown <= 0) {
          const direction = Math.sign(player.speed || 1);
          player.speed = direction * Math.max(Math.abs(player.speed), player.boostMaxSpeed * 0.84);
          player.boost = Math.min(100, player.boost + 20);
          pad.cooldown = 1.2;
          shake = Math.max(shake, 5);
          flashColor = '#00f5ff'; flash = Math.max(flash, 0.12);
          beep(920, 0.055, 0.018, 'triangle');
          addFloatingText(player.x, player.y - 40, 'BOOST!', '#00f5ff', 22);
          addCombo(50);
          addExplosion(pad.x, pad.y, '#00f5ff', 8);
        }
      }

      for (const bonus of bonuses) {
        if (bonus.taken) continue;
        bonus.pulse += dt * 5;
        if (distance(player.x, player.y, bonus.x, bonus.y) < 36) {
          bonus.taken = true;
          totalBonusesTaken++;
          const pts = bonus.type === 'score' ? 300 : 150;
          player.score += pts * comboMultiplier;
          addCombo(pts);
          if (bonus.type === 'boost') { player.boost = 100; addFloatingText(player.x, player.y - 50, 'NITRO!', '#00f5ff'); }
          if (bonus.type === 'repair') { player.hp = Math.min(100, player.hp + 30); player.invincible = 0.8; addFloatingText(player.x, player.y - 50, '+HP', '#3cff7e'); }
          if (bonus.type === 'time') { timeLeft = Math.min(120, timeLeft + 10); addFloatingText(player.x, player.y - 50, '+10s', '#ffd166'); }
          if (bonus.type === 'score') addFloatingText(player.x, player.y - 50, `+${pts * comboMultiplier}`, '#ff9900');
          flashColor = '#00f5ff'; flash = Math.max(flash, 0.13);
          beep(bonus.type === 'repair' ? 660 : bonus.type === 'time' ? 520 : 780, 0.05, 0.015, 'triangle');
          addExplosion(bonus.x, bonus.y, bonus.type === 'repair' ? '#3cff7e' : '#ffd166', 10);
        }
      }

      // Combo timer
      if (combo > 0) {
        comboTimer -= dt;
        if (comboTimer <= 0) { combo = 0; comboMultiplier = 1; comboShowTimer = 0; }
      }
      if (comboShowTimer > 0) comboShowTimer -= dt;
      updateComboDisplay();

      if (rectsOverlap(carRect, destination)) {
        endGame(true, 'delivered');
      }
      if (player.hp <= 0) endGame(false, 'destroyed');

      player.score += dt * Math.max(0, player.speed) * 0.045;
      camera.x = clamp(player.x - window.innerWidth / 2, 0, WORLD.width - window.innerWidth);
      camera.y = clamp(player.y - window.innerHeight / 2, 0, WORLD.height - window.innerHeight);

      for (let i = carTrails.length - 1; i >= 0; i--) {
        carTrails[i].life -= dt;
        if (carTrails[i].life <= 0) carTrails.splice(i, 1);
      }
      for (let i = exhaustParticles.length - 1; i >= 0; i--) {
        exhaustParticles[i].x += exhaustParticles[i].vx * dt;
        exhaustParticles[i].y += exhaustParticles[i].vy * dt;
        exhaustParticles[i].life -= dt;
        if (exhaustParticles[i].life <= 0) exhaustParticles.splice(i, 1);
      }
      for (let i = explosionParticles.length - 1; i >= 0; i--) {
        explosionParticles[i].x += explosionParticles[i].vx * dt;
        explosionParticles[i].y += explosionParticles[i].vy * dt;
        explosionParticles[i].vx *= 0.92; explosionParticles[i].vy *= 0.92;
        explosionParticles[i].life -= dt;
        if (explosionParticles[i].life <= 0) explosionParticles.splice(i, 1);
      }
      for (let i = floatingTexts.length - 1; i >= 0; i--) {
        floatingTexts[i].y += floatingTexts[i].vy * dt;
        floatingTexts[i].life -= dt * 1.4;
        if (floatingTexts[i].life <= 0) floatingTexts.splice(i, 1);
      }

      if (Math.random() < 0.20) {
        cityParticles.push({
          x: camera.x + Math.random() * window.innerWidth,
          y: camera.y - 20, vy: 65 + Math.random() * 110,
          life: 1.3 + Math.random() * 0.7
        });
      }
      if (distance(player.x, player.y, destination.x + destination.w / 2, destination.y + destination.h / 2) < 420 && Math.random() < 0.5) {
        finishSparks.push({
          x: destination.x + Math.random() * destination.w,
          y: destination.y + destination.h + Math.random() * 40,
          vx: -60 + Math.random() * 120, vy: -120 - Math.random() * 160,
          life: 0.55 + Math.random() * 0.35
        });
      }
      for (let i = finishSparks.length - 1; i >= 0; i--) {
        finishSparks[i].x += finishSparks[i].vx * dt;
        finishSparks[i].y += finishSparks[i].vy * dt;
        finishSparks[i].life -= dt;
        if (finishSparks[i].life <= 0) finishSparks.splice(i, 1);
      }
      for (let i = cityParticles.length - 1; i >= 0; i--) {
        cityParticles[i].y += cityParticles[i].vy * dt;
        cityParticles[i].life -= dt;
        if (cityParticles[i].life <= 0) cityParticles.splice(i, 1);
      }
      shake *= Math.pow(0.82, dt * 60);
      flash = Math.max(0, flash - dt * 2.2);
    }

    function addCombo(pts) {
      combo++;
      comboTimer = 4.5;
      comboMultiplier = Math.min(4, 1 + Math.floor(combo / 3));
      comboShowTimer = 1.0;
    }

    function resetCombo() {
      if (combo > 2) addFloatingText(player.x, player.y - 30, 'COMBO LOST!', '#ff2bd6', 14);
      combo = 0; comboMultiplier = 1; comboTimer = 0;
    }

    function updateComboDisplay() {
      if (comboShowTimer > 0 && combo >= 2) {
        comboDisplay.style.opacity = Math.min(1, comboShowTimer * 3);
        comboDisplay.textContent = `×${comboMultiplier} COMBO`;
        const t = performance.now() / 1000;
        const hue = (t * 60) % 360;
        comboDisplay.style.color = `hsl(${hue}, 100%, 60%)`;
        comboDisplay.style.textShadow = `0 0 30px hsl(${hue}, 100%, 60%)`;
        comboDisplay.style.transform = `translate(-50%, -50%) scale(${1 + (1 - comboShowTimer) * 0.4})`;
      } else {
        comboDisplay.style.opacity = 0;
      }
    }

    function getPlayerRect() { return { x: player.x - player.w / 2, y: player.y - player.h / 2, w: player.w, h: player.h }; }

    function endGame(win, reason) {
      state = win ? 'win' : 'lose';
      if (engineGain) engineGain.gain.value = 0.002;
      beep(win ? 880 : 110, 0.2, 0.018, win ? 'triangle' : 'sawtooth');
      if (win) { beep(1320, 0.15, 0.012, 'triangle'); }
      dangerBar.style.transform = 'scaleX(0)';

      const baseScore = Math.floor(player.score);
      const timeBonus = win ? Math.floor(timeLeft * 28) : 0;
      const hpBonus = win ? Math.floor(player.hp * 12) : 0;
      const bonusBonus = totalBonusesTaken * 80;
      const finalScore = baseScore + timeBonus + hpBonus + bonusBonus;

      let rank = 'C', rankClass = 'rank-C';
      if (finalScore > 4000) { rank = 'B'; rankClass = 'rank-B'; }
      if (finalScore > 7000) { rank = 'A'; rankClass = 'rank-A'; }
      if (finalScore > 11000) { rank = 'S'; rankClass = 'rank-S'; }

      result.classList.remove('hidden');
      if (win) {
        resultTitle.textContent = 'DELIVERED!';
        document.getElementById('rankDisplay').innerHTML = `<div class="rank-badge ${rankClass}">${rank}</div>`;
        document.getElementById('scoreBreakdown').innerHTML = `
          <div class="score-item">Базовый: <span>${baseScore}</span></div>
          <div class="score-item">Время ×28: <span>+${timeBonus}</span></div>
          <div class="score-item">HP ×12: <span>+${hpBonus}</span></div>
          <div class="score-item">Бонусы: <span>+${bonusBonus}</span></div>
          <div class="score-item" style="color:#ffd166; font-size:17px">ИТОГ: <span style="color:#ffd166">${finalScore}</span></div>
        `;
        resultText.textContent = 'Картридж доставлен. ARCADE SCENE SAVED. Аркадная сцена выжила!';
      } else {
        document.getElementById('rankDisplay').innerHTML = '';
        document.getElementById('scoreBreakdown').innerHTML = `<div class="score-item">Счёт: <span>${baseScore}</span></div>`;
        resultTitle.textContent = 'GAME OVER';
        if (reason === 'timeout') resultText.textContent = 'Время вышло. Последний аркадный клуб погас. ARCADE SCENE LOST.';
        else resultText.textContent = 'Машина уничтожена. Картридж потерян в неоновом шуме. ARCADE SCENE LOST.';
      }
    }

    // ===================== DRAWING =====================

    function draw() {
      const w = window.innerWidth; const h = window.innerHeight;
      ctx.clearRect(0, 0, w, h);
      const sx = (Math.random() - 0.5) * shake;
      const sy = (Math.random() - 0.5) * shake;
      ctx.save();
      ctx.translate(-camera.x + sx, -camera.y + sy);
      drawBackground();
      drawFarCity();
      drawRoads();
      drawRoadLights();
      drawRouteBeacons();
      drawDestination();
      drawBuildings();
      drawNeonSigns();
      drawGlitches();
      drawBoostPads();
      drawBonuses();
      drawRadarPings();
      drawDrones();
      drawCarTrails();
      drawExhaustParticles();
      drawExplosionParticles();
      drawPlayer();
      drawFinishSparks();
      drawCityParticles();
      drawFloatingTexts();
      ctx.restore();
      drawDirectionArrow();
      drawHud();
      if (minimapEnabled) drawMinimap();
      drawVignette();
      if (paused) drawPauseOverlay();
      if (flash > 0) {
        const rgb = flashColor === '#00f5ff' ? '0,245,255' : '255,43,214';
        ctx.fillStyle = `rgba(${rgb}, ${flash * 0.5})`;
        ctx.fillRect(0, 0, w, h);
      }
    }

    function drawBackground() {
      ctx.fillStyle = '#070012'; ctx.fillRect(0, 0, WORLD.width, WORLD.height);
      // Perspective grid
      ctx.save();
      ctx.strokeStyle = 'rgba(0,245,255,0.09)'; ctx.lineWidth = 1;
      for (let x = 0; x < WORLD.width; x += 80) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, WORLD.height); ctx.stroke();
      }
      for (let y = 0; y < WORLD.height; y += 80) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(WORLD.width, y); ctx.stroke();
      }
      // Subtle diagonal glow
      ctx.restore();
    }

    function drawFarCity() {
      ctx.save();
      const baseY = camera.y + window.innerHeight - 160;
      for (let i = 0; i < 40; i++) {
        const x = ((i * 173) % WORLD.width);
        const bh = 75 + ((i * 47) % 180);
        const bw = 44 + ((i * 29) % 80);
        ctx.fillStyle = i % 3 === 0 ? 'rgba(14,0,38,0.65)' : i % 3 === 1 ? 'rgba(22,0,50,0.52)' : 'rgba(8,0,22,0.7)';
        ctx.fillRect(x, baseY - bh, bw, bh);
        const gcolor = i % 2 === 0 ? 'rgba(0,245,255,0.3)' : 'rgba(255,43,214,0.25)';
        ctx.strokeStyle = gcolor; ctx.lineWidth = 1; ctx.strokeRect(x, baseY - bh, bw, bh);
        // Windows
        ctx.fillStyle = i % 4 === 0 ? 'rgba(255,209,102,0.5)' : 'rgba(0,245,255,0.3)';
        for (let wy = baseY - bh + 10; wy < baseY - 10; wy += 18) {
          for (let wx = x + 6; wx < x + bw - 6; wx += 14) {
            if (Math.random() < 0.5) ctx.fillRect(wx, wy, 5, 7);
          }
        }
      }
      ctx.restore();
    }

    function drawRoads() {
      for (const r of roads) {
        // Road shadow
        ctx.fillStyle = 'rgba(0,0,0,0.5)'; ctx.fillRect(r.x + 4, r.y + 4, r.w, r.h);
        ctx.fillStyle = '#100822'; ctx.fillRect(r.x, r.y, r.w, r.h);
        // Road texture (subtle)
        ctx.fillStyle = 'rgba(255,255,255,0.015)';
        for (let i = 0; i < 3; i++) {
          const tx = r.x + Math.random() * r.w; const ty = r.y + Math.random() * r.h;
          ctx.fillRect(tx, ty, 2 + Math.random() * 20, 1);
        }
        ctx.strokeStyle = '#ff2bd6'; ctx.lineWidth = 3;
        ctx.shadowColor = '#ff2bd6'; ctx.shadowBlur = 14;
        ctx.strokeRect(r.x, r.y, r.w, r.h); ctx.shadowBlur = 0;
        // Center dashes
        ctx.strokeStyle = 'rgba(255,209,102,0.52)'; ctx.lineWidth = 2; ctx.setLineDash([20, 16]);
        ctx.beginPath();
        if (r.w > r.h) { ctx.moveTo(r.x + 20, r.y + r.h / 2); ctx.lineTo(r.x + r.w - 20, r.y + r.h / 2); }
        else { ctx.moveTo(r.x + r.w / 2, r.y + 20); ctx.lineTo(r.x + r.w / 2, r.y + r.h - 20); }
        ctx.stroke(); ctx.setLineDash([]);
      }
    }

    function drawRoadLights() {
      ctx.save();
      const t = performance.now() / 1000;
      for (const l of roadLights) {
        const pulse = 0.45 + Math.sin(t * 1.2 + l.phase) * 0.25;
        ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 10 + pulse * 10;
        ctx.fillStyle = `rgba(255,209,102,${0.4 + pulse * 0.38})`;
        ctx.beginPath(); ctx.arc(l.x, l.y, 4, 0, Math.PI * 2); ctx.fill();
      }
      ctx.restore();
    }

    function drawRouteBeacons() {
      if (!recommendedRouteVisible) return;
      ctx.save();
      const t = performance.now() / 1000;
      ctx.lineWidth = 5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
      ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 14;
      // Animated dash offset
      ctx.strokeStyle = 'rgba(255,209,102,0.7)';
      ctx.setLineDash([16, 12]);
      ctx.lineDashOffset = -t * 30;
      ctx.beginPath();
      ctx.moveTo(routeBeacons[0].x, routeBeacons[0].y);
      for (let i = 1; i < routeBeacons.length; i++) ctx.lineTo(routeBeacons[i].x, routeBeacons[i].y);
      ctx.stroke(); ctx.setLineDash([]); ctx.lineDashOffset = 0;

      for (let i = 0; i < routeBeacons.length; i++) {
        const b = routeBeacons[i];
        const dist = distance(player.x, player.y, b.x, b.y);
        const isNear = dist < 140;
        const pulse = 1 + Math.sin(t * 5 + i) * 0.25;
        ctx.shadowColor = isNear ? '#ffd166' : '#00f5ff';
        ctx.shadowBlur = isNear ? 22 : 10;
        ctx.fillStyle = isNear ? '#ffd166' : 'rgba(0,245,255,0.38)';
        ctx.beginPath();
        ctx.arc(b.x, b.y, (isNear ? 14 : 9) * (isNear ? pulse : 1), 0, Math.PI * 2);
        ctx.fill();
        // Label
        if (isNear) {
          ctx.fillStyle = '#080014'; ctx.font = 'bold 9px Courier New';
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(b.label, b.x, b.y);
        }
      }
      ctx.restore();
    }

    function drawDestination() {
      ctx.save();
      const t = performance.now() / 1000;
      const pulse = 0.75 + Math.sin(t * 4.5) * 0.25;
      ctx.shadowColor = '#00f5ff'; ctx.shadowBlur = 28 + pulse * 22;
      ctx.fillStyle = 'rgba(0,245,255,0.15)'; ctx.fillRect(destination.x, destination.y, destination.w, destination.h);
      ctx.strokeStyle = '#00f5ff'; ctx.lineWidth = 4;
      ctx.strokeRect(destination.x, destination.y, destination.w, destination.h);
      // Corner brackets
      const cs = 20; const cx = destination.x; const cy = destination.y;
      const cw = destination.w; const ch = destination.h;
      ctx.strokeStyle = '#ffd166'; ctx.lineWidth = 3;
      [[cx, cy, 1, 1],[cx+cw, cy, -1, 1],[cx, cy+ch, 1, -1],[cx+cw, cy+ch, -1, -1]].forEach(([bx, by, dx, dy]) => {
        ctx.beginPath(); ctx.moveTo(bx + dx * cs, by); ctx.lineTo(bx, by); ctx.lineTo(bx, by + dy * cs); ctx.stroke();
      });
      ctx.shadowBlur = 0;
      ctx.fillStyle = '#00f5ff'; ctx.font = 'bold 19px Courier New'; ctx.textAlign = 'center';
      ctx.fillText('ARCADE CLUB', destination.x + destination.w / 2, destination.y + 60);
      ctx.fillStyle = '#ffd166'; ctx.font = '11px Courier New';
      ctx.fillText('INSERT CARTRIDGE', destination.x + destination.w / 2, destination.y + 82);
      ctx.restore();
    }

    function drawBuildings() {
      const BCOLORS = ['rgba(0,245,255,0.85)', 'rgba(255,43,214,0.85)', 'rgba(255,209,102,0.6)'];
      for (const b of buildings) {
        ctx.fillStyle = '#0d0019'; ctx.fillRect(b.x + 3, b.y + 3, b.w, b.h);
        ctx.fillStyle = '#120026'; ctx.fillRect(b.x, b.y, b.w, b.h);
        ctx.strokeStyle = BCOLORS[b.colorIdx]; ctx.lineWidth = 2;
        ctx.shadowColor = BCOLORS[b.colorIdx]; ctx.shadowBlur = 8;
        ctx.strokeRect(b.x, b.y, b.w, b.h); ctx.shadowBlur = 0;
        ctx.fillStyle = 'rgba(255,209,102,0.5)';
        for (let yy = b.y + 16; yy < b.y + b.h - 10; yy += 22) {
          for (let xx = b.x + 14; xx < b.x + b.w - 10; xx += 24) {
            if (((Math.floor(xx + yy + b.x) * 17) % 11) !== 0) ctx.fillRect(xx, yy, 7, 9);
          }
        }
      }
    }

    function drawGlitches() {
      const t = performance.now() / 1000;
      for (const g of glitches) {
        const jitter = Math.sin(t * 12 + g.phase) * 3;
        ctx.fillStyle = 'rgba(255,43,214,0.2)'; ctx.fillRect(g.x + jitter, g.y, g.w, g.h);
        ctx.fillStyle = 'rgba(0,245,255,0.12)'; ctx.fillRect(g.x - jitter, g.y + 5, g.w * 0.7, g.h * 0.45);
        ctx.strokeStyle = 'rgba(255,43,214,0.65)'; ctx.lineWidth = 1; ctx.strokeRect(g.x, g.y, g.w, g.h);
        // Hazard symbol
        ctx.fillStyle = 'rgba(255,43,214,0.7)'; ctx.font = '10px Courier New'; ctx.textAlign = 'center';
        ctx.fillText('⚡', g.x + g.w / 2, g.y + g.h / 2 + 4);
      }
    }

    function drawNeonSigns() {
      ctx.save();
      const t = performance.now() / 1000;
      for (const s of neonSigns) {
        const flicker = Math.sin(t * s.flickerRate + s.phase);
        if (flicker < -0.85) continue; // flicker off
        const alpha = 0.55 + Math.sin(t + s.phase) * 0.28;
        ctx.shadowColor = s.color;
        ctx.shadowBlur = 12 + alpha * 12;
        ctx.fillStyle = `rgba(${s.color === '#00f5ff' ? '0,245,255' : '255,43,214'},${alpha})`;
        ctx.fillRect(s.x, s.y, s.w, s.h);
        ctx.strokeStyle = s.color; ctx.lineWidth = 1.5;
        ctx.strokeRect(s.x, s.y, s.w, s.h);
        ctx.shadowBlur = 0;
        ctx.fillStyle = '#080014'; ctx.font = 'bold 7px Courier New';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(s.text.slice(0, 8), s.x + s.w / 2, s.y + s.h / 2 + 1);
      }
      ctx.restore();
    }

    function drawBoostPads() {
      ctx.save();
      const t = performance.now() / 1000;
      for (const pad of boostPads) {
        const alpha = pad.cooldown > 0 ? 0.25 : 0.6 + Math.sin(t * 5 + pad.pulse) * 0.22;
        ctx.save(); ctx.translate(pad.x, pad.y); ctx.rotate(pad.angle);
        ctx.shadowColor = '#00f5ff'; ctx.shadowBlur = pad.cooldown > 0 ? 6 : 24;
        ctx.fillStyle = `rgba(0,245,255,${alpha * 0.25})`;
        ctx.fillRect(-pad.w / 2, -pad.h / 2, pad.w, pad.h);
        ctx.strokeStyle = `rgba(0,245,255,${alpha})`; ctx.lineWidth = 3;
        ctx.strokeRect(-pad.w / 2, -pad.h / 2, pad.w, pad.h);
        // Arrow
        ctx.fillStyle = `rgba(255,209,102,${alpha})`;
        ctx.beginPath(); ctx.moveTo(22, 0); ctx.lineTo(-8, -13); ctx.lineTo(-2, 0); ctx.lineTo(-8, 13); ctx.closePath(); ctx.fill();
        ctx.restore();
      }
      ctx.restore();
    }

    function drawBonuses() {
      const t = performance.now() / 1000;
      for (const b of bonuses) {
        if (b.taken) continue;
        const pulse = 1 + Math.sin(t * 5 + b.pulse) * 0.18;
        ctx.save(); ctx.translate(b.x, b.y); ctx.scale(pulse, pulse); ctx.rotate(t * 1.5);
        const color = b.type === 'boost' ? '#00f5ff' : b.type === 'repair' ? '#3cff7e' : b.type === 'score' ? '#ff9900' : '#ffd166';
        ctx.shadowColor = color; ctx.shadowBlur = 20; ctx.fillStyle = color;
        ctx.beginPath(); ctx.arc(0, 0, b.r, 0, Math.PI * 2); ctx.fill();
        ctx.shadowBlur = 0;
        ctx.fillStyle = '#080014'; ctx.font = 'bold 15px Courier New';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.rotate(-t * 1.5);
        ctx.fillText(b.type === 'boost' ? '⚡' : b.type === 'repair' ? '+' : b.type === 'score' ? '$' : 'T', 0, 1);
        ctx.restore();
      }
    }

    function drawRadarPings() {
      ctx.save();
      for (const p of radarPings) {
        ctx.strokeStyle = `rgba(255,43,214,${p.life * 0.5})`;
        ctx.lineWidth = 2;
        ctx.shadowColor = '#ff2bd6'; ctx.shadowBlur = 8;
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.stroke();
      }
      ctx.restore();
    }

    function drawDrones() {
      const t = performance.now() / 1000;
      for (const d of drones) {
        ctx.save(); ctx.translate(d.x, d.y); ctx.rotate(d.phase);
        ctx.shadowColor = d.alerted ? '#ff9900' : '#ff2bd6';
        ctx.shadowBlur = d.alerted ? 24 : 14;
        ctx.fillStyle = d.alerted ? '#2a1000' : '#240035';
        ctx.strokeStyle = d.alerted ? '#ff9900' : '#ff2bd6'; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.moveTo(0, -d.r); ctx.lineTo(d.r, 0); ctx.lineTo(0, d.r); ctx.lineTo(-d.r, 0); ctx.closePath();
        ctx.fill(); ctx.stroke();
        // Eye
        ctx.fillStyle = d.alerted ? '#ff9900' : '#ff2bd6';
        ctx.beginPath(); ctx.arc(0, 0, 5, 0, Math.PI * 2); ctx.fill();
        // Alert ring
        if (d.alerted) {
          const r2 = d.alertRadius * 0.15 * (1 + Math.sin(t * 10) * 0.3);
          ctx.strokeStyle = 'rgba(255,153,0,0.4)'; ctx.lineWidth = 1.5;
          ctx.beginPath(); ctx.arc(0, 0, r2, 0, Math.PI * 2); ctx.stroke();
        }
        ctx.restore();
      }
    }

    function drawCarTrails() {
      ctx.save();
      for (const t of carTrails) {
        const alpha = Math.max(0, t.life / 0.38);
        ctx.shadowColor = t.boost ? '#00f5ff' : '#8844ff';
        ctx.shadowBlur = t.boost ? 16 : 8;
        ctx.fillStyle = `rgba(${t.boost ? '0,245,255' : '100,50,200'},${alpha * 0.3})`;
        ctx.beginPath(); ctx.arc(t.x, t.y, t.size * alpha, 0, Math.PI * 2); ctx.fill();
      }
      ctx.restore();
    }

    function drawExhaustParticles() {
      ctx.save();
      for (const p of exhaustParticles) {
        const alpha = Math.max(0, p.life / 0.45);
        ctx.fillStyle = p.color === '#00f5ff' ? `rgba(0,245,255,${alpha * 0.6})` : `rgba(255,153,0,${alpha * 0.5})`;
        ctx.shadowColor = p.color; ctx.shadowBlur = 6;
        ctx.beginPath(); ctx.arc(p.x, p.y, 4 * alpha, 0, Math.PI * 2); ctx.fill();
      }
      ctx.restore();
    }

    function drawExplosionParticles() {
      ctx.save();
      for (const p of explosionParticles) {
        const alpha = Math.max(0, p.life);
        ctx.shadowColor = p.color; ctx.shadowBlur = 10;
        ctx.fillStyle = p.color.replace(')', `,${alpha})`).replace('rgb(', 'rgba(').replace('#ff2bd6', `rgba(255,43,214,${alpha})`).replace('#00f5ff', `rgba(0,245,255,${alpha})`).replace('#ffd166', `rgba(255,209,102,${alpha})`).replace('#3cff7e', `rgba(60,255,126,${alpha})`);
        ctx.fillRect(p.x - p.size / 2, p.y - p.size / 2, p.size, p.size);
      }
      ctx.globalAlpha = 1;
      ctx.restore();
    }

    function drawFinishSparks() {
      ctx.save();
      for (const s of finishSparks) {
        const alpha = Math.max(0, s.life / 0.9);
        ctx.globalAlpha = alpha;
        ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 14;
        ctx.fillStyle = '#ffd166';
        ctx.fillRect(s.x, s.y, 4, 4);
      }
      ctx.globalAlpha = 1; ctx.restore();
    }

    function drawCityParticles() {
      ctx.save();
      ctx.strokeStyle = 'rgba(0,245,255,0.16)'; ctx.lineWidth = 1;
      for (const p of cityParticles) {
        ctx.globalAlpha = Math.max(0, Math.min(1, p.life));
        ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p.x - 10, p.y + 20); ctx.stroke();
      }
      ctx.globalAlpha = 1; ctx.restore();
    }

    function drawFloatingTexts() {
      ctx.save();
      for (const t of floatingTexts) {
        ctx.globalAlpha = Math.max(0, t.life);
        ctx.shadowColor = t.color; ctx.shadowBlur = 16;
        ctx.fillStyle = t.color;
        ctx.font = `bold ${t.size}px Orbitron, Courier New`;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(t.text, t.x, t.y);
      }
      ctx.globalAlpha = 1; ctx.restore();
    }

    function drawPlayer() {
      const invBlink = player.invincible > 0 && Math.floor(player.invincible * 10) % 2 === 0;
      if (invBlink) return;
      ctx.save();
      ctx.translate(player.x, player.y);
      ctx.rotate(player.angle + Math.PI / 2);
      // Tilt for drift
      ctx.rotate(player.driftAngle * 0.4);
      const isBoost = keys.has('shift') && player.boost > 0;
      ctx.shadowColor = isBoost ? '#ffd166' : '#00f5ff';
      ctx.shadowBlur = isBoost ? 28 : 18;
      // Body
      ctx.fillStyle = isBoost ? '#ffd166' : '#00f5ff';
      ctx.fillRect(-player.w / 2, -player.h / 2, player.w, player.h);
      // Windshield
      ctx.fillStyle = '#080014';
      ctx.fillRect(-player.w / 2 + 5, -player.h / 2 + 7, player.w - 10, 15);
      ctx.fillRect(-player.w / 2 + 4, player.h / 2 - 13, player.w - 8, 6);
      // Wheels
      ctx.fillStyle = '#ff2bd6';
      [[-player.w/2-5, -player.h/2+5, 5, 13], [player.w/2, -player.h/2+5, 5, 13],
       [-player.w/2-5, player.h/2-19, 5, 13], [player.w/2, player.h/2-19, 5, 13]].forEach(([wx,wy,ww,wh]) => ctx.fillRect(wx,wy,ww,wh));
      // Roof stripe
      ctx.fillStyle = 'rgba(255,255,255,0.25)';
      ctx.fillRect(-player.w/2+8, -player.h/2+24, player.w-16, 4);
      // Engine flame
      if (player.speed > 160) {
        const fLen = 28 + Math.random() * 22;
        const fg = ctx.createLinearGradient(0, player.h/2, 0, player.h/2 + fLen);
        fg.addColorStop(0, isBoost ? 'rgba(0,245,255,0.9)' : 'rgba(255,209,102,0.9)');
        fg.addColorStop(1, 'rgba(255,43,214,0)');
        ctx.fillStyle = fg;
        ctx.beginPath();
        ctx.moveTo(-11, player.h/2); ctx.lineTo(0, player.h/2 + fLen); ctx.lineTo(11, player.h/2);
        ctx.fill();
      }
      ctx.restore();
    }

    function drawDirectionArrow() {
      if (state !== 'playing') return;
      const target = { x: destination.x + destination.w / 2, y: destination.y + destination.h / 2 };
      const dx = target.x - player.x; const dy = target.y - player.y;
      const angle = Math.atan2(dy, dx);
      const dist = Math.hypot(dx, dy);
      const cx = window.innerWidth / 2; const cy = 78;
      const t = performance.now() / 1000;
      const pulse = 1 + Math.sin(t * 4) * 0.15;
      ctx.save();
      ctx.translate(cx, cy); ctx.rotate(angle); ctx.scale(pulse, pulse);
      // Arrow glow
      ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 22; ctx.fillStyle = '#ffd166';
      ctx.beginPath(); ctx.moveTo(36, 0); ctx.lineTo(-18, -16); ctx.lineTo(-7, 0); ctx.lineTo(-18, 16); ctx.closePath(); ctx.fill();
      ctx.restore();
      ctx.save();
      ctx.font = 'bold 13px Orbitron, Courier New'; ctx.textAlign = 'center';
      ctx.fillStyle = '#ffd166'; ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 10;
      ctx.fillText(`CLUB · ${Math.floor(dist)}m`, cx, cy + 40);
      ctx.restore();
    }

    function drawHud() {
      if (state === 'menu') return;
      const w = window.innerWidth;
      ctx.save();

      // Time - big, prominent
      const timeColor = timeLeft < 20 ? (Math.sin(Date.now()/120) > 0 ? '#ff2bd6' : '#ff9900') : timeLeft < 40 ? '#ffd166' : '#00f5ff';
      ctx.font = 'bold 28px Orbitron, Courier New'; ctx.textAlign = 'left';
      ctx.fillStyle = timeColor; ctx.shadowColor = timeColor; ctx.shadowBlur = 14;
      ctx.fillText(`${Math.max(0, Math.ceil(timeLeft)).toString().padStart(3, '0')}`, 24, 38);
      ctx.font = '12px Share Tech Mono'; ctx.fillStyle = 'rgba(255,255,255,0.4)'; ctx.shadowBlur = 0;
      ctx.fillText('TIME', 24, 52);

      // Score
      ctx.font = 'bold 16px Orbitron, Courier New'; ctx.fillStyle = '#ffd166'; ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 8;
      ctx.fillText(`${Math.floor(player.score)}`, 100, 38);
      ctx.font = '12px Share Tech Mono'; ctx.fillStyle = 'rgba(255,255,255,0.4)'; ctx.shadowBlur = 0;
      ctx.fillText('SCORE', 100, 52);

      // Combo indicator
      if (combo >= 2) {
        ctx.font = 'bold 14px Orbitron, Courier New';
        ctx.fillStyle = '#ff9900'; ctx.shadowColor = '#ff9900'; ctx.shadowBlur = 10;
        ctx.fillText(`×${comboMultiplier}`, 230, 38);
        ctx.font = '11px Share Tech Mono'; ctx.fillStyle = 'rgba(255,255,255,0.4)'; ctx.shadowBlur = 0;
        ctx.fillText('COMBO', 230, 52);
        // Combo bar
        ctx.fillStyle = 'rgba(255,153,0,0.2)'; ctx.fillRect(220, 56, 80, 6);
        ctx.fillStyle = '#ff9900'; ctx.fillRect(220, 56, 80 * (comboTimer / 4.5), 6);
      }

      // Bars
      drawBar(24, 68, 200, 14, player.hp / 100, '#ff2bd6', 'HP');
      drawBar(24, 90, 200, 14, player.boost / 100, '#00f5ff', 'BOOST');

      // Speed indicator
      const speedKmh = Math.floor(Math.abs(player.speed) * 0.18);
      ctx.textAlign = 'right'; ctx.font = 'bold 20px Orbitron, Courier New';
      ctx.fillStyle = '#fff'; ctx.shadowColor = '#fff'; ctx.shadowBlur = 6;
      ctx.fillText(speedKmh, w - 30, 42);
      ctx.font = '11px Share Tech Mono'; ctx.fillStyle = 'rgba(255,255,255,0.4)'; ctx.shadowBlur = 0;
      ctx.fillText('km/h', w - 30, 56);

      // Top right hints
      ctx.font = '11px Share Tech Mono'; ctx.fillStyle = 'rgba(255,209,102,0.55)';
      ctx.fillText('[TAB] маршрут · [M] карта · [SPACE] пауза', w - 30, 72);

      ctx.restore();
    }

    function drawBar(x, y, w, h, value, color, label) {
      ctx.save();
      ctx.fillStyle = 'rgba(0,0,0,0.5)'; ctx.fillRect(x, y, w, h);
      ctx.strokeStyle = `${color}88`; ctx.lineWidth = 1.5; ctx.strokeRect(x, y, w, h);
      const v = clamp(value, 0, 1);
      // Bar glow
      const grad = ctx.createLinearGradient(x, y, x + w * v, y);
      grad.addColorStop(0, color + '60'); grad.addColorStop(1, color);
      ctx.fillStyle = grad; ctx.fillRect(x, y, w * v, h);
      ctx.fillStyle = '#fff'; ctx.font = 'bold 10px Share Tech Mono'; ctx.textAlign = 'left';
      ctx.textBaseline = 'middle'; ctx.shadowBlur = 0;
      ctx.fillText(label, x + 5, y + h / 2 + 0.5);
      ctx.restore();
    }

    function drawMinimap() {
      if (state !== 'playing') return;
      const mapW = Math.min(340, Math.max(280, window.innerWidth * 0.22));
      const mapH = Math.min(226, Math.max(190, window.innerHeight * 0.22));
      const x = window.innerWidth - mapW - 20;
      const y = window.innerHeight - mapH - 20;
      const sx = mapW / WORLD.width; const sy = mapH / WORLD.height;
      ctx.save();
      // Map background
      ctx.fillStyle = 'rgba(4,0,10,0.82)'; ctx.fillRect(x, y, mapW, mapH);
      ctx.strokeStyle = '#00f5ff'; ctx.lineWidth = 2; ctx.shadowColor = '#00f5ff'; ctx.shadowBlur = 8;
      ctx.strokeRect(x, y, mapW, mapH); ctx.shadowBlur = 0;

      // Roads
      ctx.fillStyle = 'rgba(255,43,214,0.35)';
      for (const r of roads) ctx.fillRect(x + r.x * sx, y + r.y * sy, r.w * sx, r.h * sy);

      // Route
      ctx.strokeStyle = '#ffd166'; ctx.lineWidth = 2; ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 4;
      ctx.beginPath();
      ctx.moveTo(x + routeBeacons[0].x * sx, y + routeBeacons[0].y * sy);
      for (let i = 1; i < routeBeacons.length; i++) ctx.lineTo(x + routeBeacons[i].x * sx, y + routeBeacons[i].y * sy);
      ctx.stroke(); ctx.shadowBlur = 0;

      // Destination
      ctx.fillStyle = 'rgba(0,245,255,0.8)';
      ctx.fillRect(x + destination.x * sx, y + destination.y * sy, destination.w * sx, destination.h * sy);

      // Drones
      ctx.fillStyle = '#ff9900';
      for (const d of drones) {
        if (d.alerted) {
          ctx.shadowColor = '#ff9900'; ctx.shadowBlur = 4;
        } else {
          ctx.fillStyle = '#ff2bd6'; ctx.shadowBlur = 0;
        }
        ctx.fillRect(x + d.x * sx - 2, y + d.y * sy - 2, 4, 4);
        ctx.fillStyle = '#ff2bd6';
      }

      // Player
      ctx.fillStyle = '#ffd166'; ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 8;
      ctx.fillRect(x + player.x * sx - 3, y + player.y * sy - 3, 6, 6);
      ctx.shadowBlur = 0;

      // Label
      ctx.font = 'bold 10px Share Tech Mono'; ctx.fillStyle = '#00f5ff'; ctx.textAlign = 'left';
      ctx.fillText('MINIMAP', x + 7, y + 14);
      ctx.fillStyle = 'rgba(255,255,255,0.3)';
      ctx.fillText(`[M]`, x + mapW - 20, y + 14);
      ctx.restore();
    }

    function drawVignette() {
      const w = window.innerWidth; const h = window.innerHeight;
      const grd = ctx.createRadialGradient(w/2, h/2, Math.min(w,h)*0.08, w/2, h/2, Math.max(w,h)*0.72);
      grd.addColorStop(0, 'rgba(0,0,0,0)'); grd.addColorStop(1, 'rgba(0,0,0,0.7)');
      ctx.fillStyle = grd; ctx.fillRect(0, 0, w, h);
    }

    function drawPauseOverlay() {
      ctx.save();
      ctx.fillStyle = 'rgba(0,0,0,0.5)'; ctx.fillRect(0, 0, window.innerWidth, window.innerHeight);
      ctx.font = 'bold 48px Orbitron, Courier New'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillStyle = '#00f5ff'; ctx.shadowColor = '#00f5ff'; ctx.shadowBlur = 30;
      ctx.fillText('PAUSE', window.innerWidth / 2, window.innerHeight / 2);
      ctx.font = '18px Share Tech Mono'; ctx.fillStyle = 'rgba(255,255,255,0.5)'; ctx.shadowBlur = 0;
      ctx.fillText('SPACE — продолжить', window.innerWidth / 2, window.innerHeight / 2 + 50);
      ctx.restore();
    }

    function loop(timestamp) {
      const dt = Math.min(0.033, (timestamp - lastTime) / 1000 || 0);
      lastTime = timestamp;
      update(dt); draw(); requestAnimationFrame(loop);
    }

    createWorldObjects();
    requestAnimationFrame(loop);
  </script>
</body>
